{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "showcase": {
      ".validate": "newData.val() === null || newData.hasChildren(['modo_id', 'modo_atual', 'imagem_url', 'status_exibicao', 'timestamp'])",
      "modo_id": { ".validate": "newData.isString()" },
      "modo_atual": { ".validate": "newData.isString() && newData.val().length <= 100" },
      "imagem_url": { ".validate": "newData.isString()" },
      "status_exibicao": { ".validate": "newData.val() === 'visivel' || newData.val() === 'oculto'" },
      "timestamp": { ".validate": "newData.isNumber()" },
      "auto_ocultar_em": { ".validate": "newData.isNumber() || newData.val() === null" },
      "$other": { ".validate": false }
    },

    "roleta_command": {
      ".validate": "newData.val() === null || newData.hasChildren(['command', 'targetId', 'timestamp'])",
      "command": { ".validate": "newData.val() === 'spin'" },
      "targetId": { ".validate": "newData.isString()" },
      "timestamp": { ".validate": "newData.isNumber()" },
      "$other": { ".validate": false }
    },

    "roleta_config": {
      "active_modes": {
        ".validate": "newData.val() === null"
      }
    },

    "custom_cards": {
      "$card_id": {
        ".validate": "newData.val() === null || newData.hasChildren(['nome', 'img'])",
        "id": { ".validate": "newData.isString()" },
        "nome": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "cat": { ".validate": "newData.isString() && newData.val().length <= 50" },
        "color": { ".validate": "newData.isString() && (newData.val().matches(/^#[0-9a-fA-F]{6}$/) || newData.val() === '')" },
        "img": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "icon": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },

    "roleta_filters": {
      "$filter_id": {
        ".validate": "newData.val() === null || newData.hasChildren(['nome'])",
        "nome": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },

    "bracket_data": {
      ".validate": "newData.val() === null"
    },

    "draft_data": {
      "saved": {
        ".validate": "newData.val() === null"
      }
    },

    "config": {
      "auto_ocultar_em": { ".validate": "newData.isNumber() || newData.val() === null" },
      "$other": { ".validate": false }
    }
  }
}
